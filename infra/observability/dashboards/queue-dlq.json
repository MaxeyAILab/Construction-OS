{
  "title": "ConstructionOS — Outbox Relay & Consumer Queues",
  "uid": "cos-queue-dlq",
  "tags": ["constructionos", "events", "queue"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Outbox relay queue depth (waiting + delayed)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "outbox_relay_queue_depth", "legendFormat": "depth" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Outbox relay throughput (claimed vs published, per s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(outbox_relay_claimed_total[5m])", "legendFormat": "claimed" },
        { "expr": "rate(outbox_relay_published_total[5m])", "legendFormat": "published" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Outbox relay batch duration — P95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(outbox_relay_batch_duration_ms_bucket[5m])))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Dead-lettered events by consumer (per s) — alert-worthy if > 0",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (consumer, subject) (rate(events_dead_lettered_total[5m]))",
          "legendFormat": "{{consumer}} / {{subject}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Consumed events by outcome (ack vs nak, per s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (consumer, outcome) (rate(events_consumed_total[5m]))",
          "legendFormat": "{{consumer}} / {{outcome}}"
        }
      ]
    }
  ]
}
