{
  "title": "ConstructionOS API — RED",
  "uid": "cos-api-red",
  "tags": ["constructionos", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Metric name note",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Queries below assume the OTel Collector's Prometheus exporter translates `http.server.request.duration` (the stable OTel HTTP server semconv metric, unit `s`) to `http_server_request_duration_seconds_{bucket,sum,count}`. Verify the exact name in Grafana Explore against the live collector — exporter versions occasionally differ on suffixing — and adjust the panel queries below if it doesn't match."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate by route (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (5xx / total)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency — P95 / P99 (NFR-1: P95≤300ms, P99≤800ms)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 11 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P99"
        }
      ]
    }
  ]
}
