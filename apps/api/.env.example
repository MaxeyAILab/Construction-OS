NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Supabase Postgres connection string (Project Settings → Database → Connection string → URI).
# Use the pooled (pgbouncer, port 6543) URL for the running API; the direct
# (port 5432) URL for drizzle-kit migrations, since migrations need a
# session-mode connection.
DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# All three secrets below: generate with `openssl rand -base64 32` (or
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))").
# Deliberately separate secrets (architecture.md §11, §16): a leaked magic-link
# or MFA-encryption key shouldn't also let someone forge API access tokens.
JWT_ACCESS_SECRET=
MAGIC_LINK_SECRET=
MFA_ENCRYPTION_KEY=

# File pipeline (architecture.md §13) — S3-compatible object store. Point
# S3_ENDPOINT at a local MinIO or R2 for dev; leave unset to use real AWS.
S3_BUCKET=constructionos-dev
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ClamAV clamd daemon (virus scan step). Defaults assume clamd running
# locally on its standard port.
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
