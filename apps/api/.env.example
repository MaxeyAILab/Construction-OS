NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Supabase Postgres connection string (Project Settings → Database → Connection string → URI).
# Use the pooled (pgbouncer, port 6543) URL for the running API; the direct
# (port 5432) URL for drizzle-kit migrations, since migrations need a
# session-mode connection.
DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
