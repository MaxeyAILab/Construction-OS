NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Supabase Postgres connection string (Project Settings → Database → Connection string → URI).
# Use the pooled (pgbouncer, port 6543) URL for the running API; the direct
# (port 5432) URL for drizzle-kit migrations, since migrations need a
# session-mode connection.
DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

REDIS_URL=redis://localhost:6379

# All three secrets below: generate with `openssl rand -base64 32` (or
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))").
# Deliberately separate secrets (architecture.md §11, §16): a leaked magic-link
# or MFA-encryption key shouldn't also let someone forge API access tokens.
JWT_ACCESS_SECRET=
MAGIC_LINK_SECRET=
MFA_ENCRYPTION_KEY=
