{
  "expo": {
    "name": "ConstructionOS",
    "slug": "constructionos",
    "scheme": "constructionos",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0B1220"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-router"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.constructionos.app"
    },
    "android": {
      "package": "com.constructionos.app"
    }
  }
}
